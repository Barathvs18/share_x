# Copy this file to .env and fill in your actual values
SECRET_KEY=your-very-long-random-secret-key-here
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ── Blockchain (Local Hardhat) ──────────────────────────────
# Get the contract address from: npx hardhat run scripts/deploy.js --network localhost
CONTRACT_ADDRESS=0xYourDeployedContractAddress
HARDHAT_RPC_URL=http://127.0.0.1:8545
# Hardhat Account #0 private key (shown when you run: npx hardhat node)
BLOCKCHAIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
